<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Untuk Mas Asib ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: #0f2027;
    color: white;
    overflow: hidden;
}

.slide {
    height: 100vh;
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
}

.active {
    display: flex;
}

.card {
    background: rgba(255,255,255,0.05);
    padding: 25px;
    border-radius: 20px;
    width: 85%;
    max-width: 350px;
}

button {
    padding: 12px 20px;
    border-radius: 20px;
    border: none;
    margin-top: 15px;
    cursor: pointer;
}

.btn {
    background: linear-gradient(90deg,#ff416c,#ff4b2b);
    color: white;
}

.chat {
    background: #111;
    border-radius: 15px;
    padding: 10px;
    width: 90%;
    max-width: 350px;
}

.bubble {
    background: #25D366;
    padding: 10px;
    margin: 5px;
    border-radius: 10px;
    text-align: left;
    color: black;
}

img {
    width: 100%;
    border-radius: 15px;
}

.heart {
    position: absolute;
    animation: fall linear infinite;
}

@keyframes fall {
    to { transform: translateY(100vh); }
}
</style>
</head>

<body>

<!-- SLIDE 1 -->
<div class="slide active">
    <div class="card">
        <h2>Hai, Mas Asib 😘</h2>
        <p>Kamu itu kayak THR… selalu aku tunggu tiap hari 😆💕</p>
        <button class="btn" onclick="next()">Mulai 💖</button>
    </div>
</div>

<!-- SLIDE 2 -->
<div class="slide">
    <div class="card">
        <p>Kamu tau ga? 🥺</p>
        <p>Lebaran itu setahun sekali...</p>
        <p>Tapi kangen aku ke kamu tiap hari 😭💕</p>
        <button class="btn" onclick="next()">Lanjut 👉</button>
    </div>
</div>

<!-- SLIDE 3 -->
<div class="slide">
    <div class="card">
        <p>Di hari yang suci ini...</p>
        <p>Aku minta maaf ya 🙏</p>
        <p>Kalau aku sering nyebelin 😅</p>
        <button class="btn" onclick="next()">Lanjut ❤️</button>
    </div>
</div>

<!-- SLIDE 4 (BAPER TYPEWRITER) -->
<div class="slide">
    <div class="card">
        <p id="typingText"></p>
        <button class="btn" onclick="next()">Lanjut 😭</button>
    </div>
</div>

<!-- SLIDE 5 (CHAT GOMBALAN) -->
<div class="slide">
    <div class="chat">
        <div class="bubble">Sayang 😘</div>
        <div class="bubble">Maafin aku ya 🙏</div>
        <div class="bubble">Aku tau aku banyak kurang 😔</div>
        <div class="bubble">Tapi satu hal...</div>
        <div class="bubble">Aku ga pernah kurang sayang sama kamu ❤️</div>
        <div class="bubble">Aku ga mau kehilangan kamu 😭</div>
    </div>
    <button class="btn" onclick="next()">Aku juga sayang 💕</button>
</div>

<!-- SLIDE 6 -->
<div class="slide">
    <div class="card">
        <p>Kamu itu bukan cuma tempat aku pulang 🥺</p>
        <p>Tapi juga alasan aku bertahan ❤️</p>
        <button class="btn" onclick="next()">Terakhir 😍</button>
    </div>
</div>

<!-- SLIDE 7 (ENDING) -->
<div class="slide">
    <div class="card">
        <img src="IMG-20260125-WA0027.jpg">
        <p>Aku mungkin bukan yang terbaik...</p>
        <p>Tapi aku ga akan berhenti berusaha buat kamu 💖</p>
        <p>Terima kasih udah sabar ngadepin aku 😭</p>
        <h3>I Love You, Mas Asib ❤️</h3>
    </div>
</div>

<!-- MUSIK -->
<audio id="musik" loop>
    <source src="https://files.catbox.moe/8lqk2l.mp3">
</audio>

<script>
let slides = document.querySelectorAll(".slide");
let index = 0;

function next(){
    document.getElementById("musik").play();

    slides[index].classList.remove("active");
    index++;
    if(index >= slides.length) index = slides.length-1;
    slides[index].classList.add("active");

    if(index === 3){
        startTyping();
    }
}

/* TYPEWRITER */
let text = "Kamu tau ga...\nKamu itu orang paling sabar yang pernah aku temuin 🥺\n\nKamu tetap bertahan walaupun aku sering salah...\nKadang egois...\nDan sering bikin kamu capek 😔\n\nTapi kamu ga pernah pergi...\n\nDan dari situ aku sadar...\nAku ga mau kehilangan kamu 😭❤️";

let iText = 0;

function startTyping(){
    document.getElementById("typingText").innerHTML = "";
    iText = 0;
    typeWriter();
}

function typeWriter() {
    if (iText < text.length) {
        document.getElementById("typingText").innerHTML += text.charAt(iText);
        iText++;
        setTimeout(typeWriter, 40);
    }
}

/* SWIPE */
let startY = 0;

document.addEventListener("touchstart", e=>{
    startY = e.touches[0].clientY;
});

document.addEventListener("touchend", e=>{
    let endY = e.changedTouches[0].clientY;
    if(startY - endY > 50){
        next();
    }
});

/* LOVE */
setInterval(()=>{
    let love = document.createElement("div");
    love.innerHTML="❤️";
    love.className="heart";
    love.style.left=Math.random()*100+"vw";
    love.style.animationDuration=(Math.random()*3+2)+"s";
    document.body.appendChild(love);

    setTimeout(()=>love.remove(),4000);
},300);
</script>

</body>
</html>
